APP_PROFILES=football
# Alternative test profile file can be stored in .env.test
# and launched via npm run check:test / npm run start:test.

# Start-time safety checks: fail fast before polling when critical integrations are broken.
START_PREFLIGHT_CHECK=true
START_PREFLIGHT_REQUIRE_VK_PHOTO=true

# Optional: use a proxy/mirror endpoint if api.telegram.org is unstable.
# Example: TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_API_BASE_URL=

# Optional Telegram proxy pool (for Bot API HTTPS requests).
# Supported: socks5://..., socks://..., http://..., https://..., tg://socks?...
# Not supported for Bot API: tg://proxy?... (MTProto proxies are skipped).
# You can set either TELEGRAM_PROXY_POOL (comma/newline separated) or numbered keys.
TELEGRAM_PROXY_POOL=
TELEGRAM_PROXY_1=
TELEGRAM_PROXY_2=
TELEGRAM_PROXY_DIRECT_FALLBACK=true
TELEGRAM_PROXY_CONNECT_TIMEOUT_MS=10000
# Faster/slower Telegram check tuning (affects npm run check getMe only).
TELEGRAM_CHECK_TIMEOUT_MS=25000
TELEGRAM_CHECK_RETRIES=1
TELEGRAM_CHECK_RETRY_DELAY_MS=300

FOOTBALL_TELEGRAM_BOT_TOKEN=
FOOTBALL_TELEGRAM_SOURCE_CHAT_USERNAME=

# Community token (works for basic posting depending on token rights)
FOOTBALL_VK_ACCESS_TOKEN=
FOOTBALL_VK_GROUP_ID=

# User token from a VK account that manages the group.
# Used for photo upload methods (photos.getWallUploadServer / photos.saveWallPhoto).
FOOTBALL_VK_MEDIA_ACCESS_TOKEN=
