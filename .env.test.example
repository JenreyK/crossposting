# Copy to .env.test and fill with real values.
# This file is safe to commit (no secrets).

APP_PROFILES=football,flowers

# Start safety checks
START_PREFLIGHT_CHECK=true
START_PREFLIGHT_REQUIRE_VK_PHOTO=true

# Separate state for test environment
OFFSETS_STATE_FILE=.runtime/offsets.test.json

# Optional Telegram proxy
TELEGRAM_PROXY_1=
TELEGRAM_PROXY_DIRECT_FALLBACK=false
TELEGRAM_PROXY_CONNECT_TIMEOUT_MS=10000
TELEGRAM_CHECK_TIMEOUT_MS=25000
TELEGRAM_CHECK_RETRIES=1
TELEGRAM_CHECK_RETRY_DELAY_MS=300

# ------------------------
# Profile: football (Хазар)
# ------------------------
FOOTBALL_PROCESSED_STATE_FILE=.runtime/football.test.processed.json
FOOTBALL_POST_PREFIX=[TEST][FOOTBALL]
FOOTBALL_TELEGRAM_BOT_TOKEN=
FOOTBALL_TELEGRAM_SOURCE_CHAT_USERNAME=
FOOTBALL_VK_GROUP_ID=
FOOTBALL_VK_ACCESS_TOKEN=
FOOTBALL_VK_MEDIA_ACCESS_TOKEN=

# ------------------------
# Profile: flowers (Цветы)
# ------------------------
FLOWERS_PROCESSED_STATE_FILE=.runtime/flowers.test.processed.json
FLOWERS_POST_PREFIX=[TEST][FLOWERS]
FLOWERS_TELEGRAM_BOT_TOKEN=
FLOWERS_TELEGRAM_SOURCE_CHAT_USERNAME=
FLOWERS_VK_GROUP_ID=
FLOWERS_VK_ACCESS_TOKEN=
FLOWERS_VK_MEDIA_ACCESS_TOKEN=

# Optional MAX for flowers
# FLOWERS_MAX_ACCESS_TOKEN=
# FLOWERS_MAX_CHAT_ID=
